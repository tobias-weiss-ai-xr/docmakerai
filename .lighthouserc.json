{
  "ci": {
    "collect": {
      "url": [
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo6/",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/calendar/create-event",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/mail/compose/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "total-blocking-time": ["error", { "maxNumericValue": 300 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
