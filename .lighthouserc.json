{
  "ci": {
    "collect": {
      "url": [
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo6/",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/sogo-calendar-create-event/",
        "https://tobias-weiss-ai-xr.github.io/docmakerai/sogo5/sogo-mail-compose/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "total-blocking-time": ["error", { "maxNumericValue": 600 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "interactive": ["warn"],
        "color-contrast": ["warn"],
        "csp-xss": ["off"],
        "unsized-images": ["warn"],
        "unused-javascript": ["warn"],
        "unused-css-rules": ["warn"],
        "dom-size": ["warn"],
        "total-byte-weight": ["warn"],
        "non-composited-animations": ["warn"],
        "bootup-time": ["warn"],
        "mainthread-work-breakdown": ["warn"],
        "uses-long-cache-ttl": ["warn"]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
